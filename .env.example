# ET (English Teacher) - Environment Variables Template
# Copy this file to .env.local and update the values

# LLM - LM Studio (Gemma-4-e4b)
ET_LLM_BASE_URL=http://127.0.0.1:1234/v1
ET_LLM_MODEL=google/gemma-4-e4b

# Speech-to-Text - Faster Whisper
ET_STT_BASE_URL=http://localhost:8100

# Text-to-Speech - Kokoro/Piper
ET_TTS_BASE_URL=http://localhost:8200

# Database
ET_DATABASE_PATH=./data/database.db

# Storage
ET_STORAGE_PATH=./storage
